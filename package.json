{
  "name": "light-fakery",
  "version": "0.7.1",
  "description": "A lightweight library for generating fake data",
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "oxlint",
    "prebuild": "rimraf ./dist",
    "release": "release-it --verbose",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mniebling/light-fakery.git"
  },
  "author": "Mike Niebling",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mniebling/light-fakery/issues"
  },
  "homepage": "https://light-fakery.netlify.app",
  "devDependencies": {
    "@mniebling/lint-config": "0.4.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "release-it": "20.2.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitepress": "1.6.4",
    "vitest": "4.1.8"
  }
}
